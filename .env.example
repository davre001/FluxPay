# FluxPay uses per-app env files — see:
#   backend/.env.example   (Render / backend secrets)
#   frontend/.env.example  (Vercel / NEXT_PUBLIC_* + server-only keys)
#
# This repo-root .env is an OPTIONAL shared fallback: the backend loader reads
# backend/.env first, then this root .env to fill any gaps. Put backend vars here
# if you prefer a single file. Real platform env (Render/Vercel) always wins.

NODE_ENV=development
DATABASE_URL=
