# ── FluxPay backend (Render) ────────────────────────────────────────────────
# Copy to backend/.env and fill in. The loader also reads the repo-root .env as a
# fallback for shared vars. Real platform env (Render) always wins over files.

# Server
PORT=8000                       # config default is 8000 (Render injects its own)
NODE_ENV=development            # 'production' on Render
FRONTEND_URL=http://localhost:3000   # CORS origin; set to your Vercel URL in prod. '*' if unset.

# Database (Neon Postgres). Either name works — it has shown up as both.
# Leave BOTH empty to run with in-memory repositories (data resets on restart).
DATABASE_URL=
# POSTGREL_URL=                 # alias accepted if DATABASE_URL is unset

# ── Chain selection (see backend/src/config/chains.ts) ──
NETWORK_MODE=mainnet            # mainnet (default) | testnet (Base Sepolia)
# ACTIVE_CHAIN_ID=8453          # optional: pin a specific chain within the mode
# Optional per-chain RPC overrides (defaults are public RPCs):
# RPC_1= RPC_8453= RPC_42161= RPC_10= RPC_137= RPC_56= RPC_59144= RPC_534352= RPC_84532=

# ── Web3Auth (verifies the idToken the frontend sends) ──
WEB3AUTH_CLIENT_ID=             # checks token audience; empty skips that check
WEB3AUTH_VERIFICATION_KEY=      # static PEM public key (Dashboard → Token verification); preferred over JWKS
JWKS_ENDPOINT=https://api-auth.web3auth.io/.well-known/jwks.json
WEB3AUTH_ISSUER=web3auth.io,https://api-auth.web3auth.io
# DEVNET ONLY: skip server-side signature check (Sapphire Devnet rotates keys).
# MUST be false on mainnet. Currently TRUE for the hackathon (devnet).
WEB3AUTH_ALLOW_UNVERIFIED=true

# ── Faucet (TESTNET ONLY — one-time $2 USDC welcome drip) ──
FAUCET_PRIVATE_KEY=             # wallet that sends the drip; no-op if unset. Force-disabled on mainnet.
FAUCET_DRIP_USDC=2

# ── Autonomous release agents ──
# Platform agent that redeems brand ERC-7715 grants (ERC-7710). Defaults to the faucet key.
AGENT_PRIVATE_KEY=
# A2A settlement agent that gets a narrowed per-job permission and does the actual USDC release.
SETTLEMENT_AGENT_PRIVATE_KEY=

# ── Venice AI (verifies creator deliverables; OpenAI-compatible) ──
VENICE_API_KEY=                 # no-op if unset
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=claude-opus-4-7    # vision-capable; list via GET {baseUrl}/models

# ── Gemini AI (TESTING FALLBACK — used only when VENICE_API_KEY is unset) ──
GEMINI_API_KEY=                 # no-op if unset; Venice takes priority when both are set
GEMINI_MODEL=gemini-2.5-flash   # vision-capable; used via OpenAI-compatible endpoint

# ── Social OAuth "Connect account" (YouTube + X; IG/TikTok deferred) ──
# Verifies handle ownership and snapshots followers / verified / account age.
# Each provider is enabled only when BOTH its id and secret are set.
# OAUTH_CALLBACK_URL must be the FRONTEND page that receives ?code&state and be
# registered as the redirect URI in each provider app. Defaults to
# ${FRONTEND_URL}/social/callback.
OAUTH_CALLBACK_URL=
GOOGLE_CLIENT_ID=               # Google Cloud OAuth client (enable YouTube Data API v3)
GOOGLE_CLIENT_SECRET=
TWITTER_CLIENT_ID=             # X/Twitter OAuth 2.0 client (reading users/me may need a paid tier)
TWITTER_CLIENT_SECRET=

# ── 1Shot relayer (MAINNET payout rail; permissionless, no API key) ──
ONESHOT_RELAYER_URL=https://relayer.1shotapi.com/relayers
# ONESHOT_CHAIN_ID=             # defaults to active mainnet chain (Base on testnet)

# ── Seeding ──
# Demo deals seed. Set to false once you're on real data so it never reseeds/clears
# jobs/milestones/applications again. See backend/src/utils/seedData.ts (SEED_VERSION).
SEED_DEMO_DATA=true

# Legacy/optional (older single-escrow path)
# ETHEREUM_RPC_URL=
# CONTRACT_ADDRESS=
