# Backend Environment Variables for Render
# Set these in Render Dashboard → Environment

# Database (Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (Render Redis)
REDIS_URL=redis://username:password@host:port

# JWT/Auth
SECRET_KEY=your-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
FRONTEND_URL=https://your-frontend-url.vercel.app
CORS_ORIGINS=["https://your-frontend-url.vercel.app"]

# Blockchain (Morph Hoodi)
CHAIN_ID=2910
RPC_URL=https://rpc-hoodi.morphl2.io
COORDINATOR_PRIVATE_KEY=your_coordinator_wallet_key

# Smart Contracts
USDC_ADDRESS=0x2CeF50c5C6059F43180b1d91EFA354A9A837AdE1
ESCROW_FACTORY_ADDRESS=0x58B92620Ce2Fa3dD61f0143Ea4f1bbF961130856

# Logging
LOG_LEVEL=INFO

# API Settings
API_TITLE=FluxPay API
API_VERSION=0.1.0
