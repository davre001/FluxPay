# ── FluxPay frontend (Vercel / Next.js) ─────────────────────────────────────
# Copy to frontend/.env.local and fill in. NEXT_PUBLIC_* are exposed to the
# browser (safe for public ids/URLs only). Vars WITHOUT the prefix are server-only
# (read inside Next API routes / Vercel functions).

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000   # set to your Render backend URL in prod

# Web3Auth (MetaMask Embedded Wallets) — clientId is public/safe to expose
NEXT_PUBLIC_CLIENT_ID=

# Backend agent wallet that redeems milestone permissions — the address a brand
# grants the ERC-7715 permission to (required for the grant flow to work).
NEXT_PUBLIC_AGENT_ADDRESS=

# ── Default chain display fallbacks (config/settings.ts) ──
# Per-chain data is resolved from config/chains.ts; these are only initial defaults.
NEXT_PUBLIC_CHAIN_ID=8453                # default display chain (Base)
NEXT_PUBLIC_CHAIN_NAME=Base
NEXT_PUBLIC_RPC_URL=
NEXT_PUBLIC_EXPLORER_URL=https://basescan.org
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_ESCROW_FACTORY_ADDRESS=

# ── Account Abstraction bundlers (per chain; from Pimlico/ZeroDev/etc.) ──
# A chain with no bundler falls back to the plain embedded EOA, so set only the
# chains you actually demo on.
NEXT_PUBLIC_BUNDLER_ETHEREUM=
NEXT_PUBLIC_BUNDLER_BASE=
NEXT_PUBLIC_BUNDLER_ARBITRUM=
NEXT_PUBLIC_BUNDLER_SEPOLIA=
NEXT_PUBLIC_BUNDLER_BASE_SEPOLIA=

# ── Sponsored-gas paymasters (per chain) ──
# A chain with a bundler but no paymaster still works — the user just pays gas.
NEXT_PUBLIC_PAYMASTER_ETHEREUM=
NEXT_PUBLIC_PAYMASTER_BASE=
NEXT_PUBLIC_PAYMASTER_ARBITRUM=
NEXT_PUBLIC_PAYMASTER_SEPOLIA=
NEXT_PUBLIC_PAYMASTER_BASE_SEPOLIA=

# ── Server-only (used by the /api/balances Next route — NO NEXT_PUBLIC prefix) ──
GOLDRUSH_API_KEY=               # primary balances/metadata/USD source (Covalent/GoldRush)
ALCHEMY_API=                    # fallback balances provider (EVM)
